# Copy this file to ".env" and fill in your real key.
# ".env" is git-ignored so your key never gets committed.

# Your Apollo.io MASTER API key (People Search requires a master key).
# Create one at: Apollo → Settings → Integrations → API.
APOLLO_API_KEY=

# Optional overrides:
# PORT=8787
# ALLOW_ORIGIN=*           # set to your GitHub Pages origin in production
# MOCK=1                   # force fake data (no network/key needed) for testing

# Phone reveal is asynchronous: Apollo posts phone numbers to a webhook, so the
# proxy must be reachable from the public internet. Set this to the proxy's
# public base URL (e.g. an ngrok tunnel or your deployed host). Leave blank to
# disable phone reveal.
# WEBHOOK_BASE_URL=https://your-proxy.example.com

# ---- Gmail auto-status (optional) ----
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console,
# enable the Gmail API, and add this proxy's /api/gmail/callback as an
# authorized redirect URI. Read-only scope is used.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8787/api/gmail/callback
# APP_RETURN_URL=http://localhost:8000   # optional: link back to the app after connecting

# ---- Live prices (optional) ----
# LME/SMM official data is licensed; this adapter normalizes a provider you
# choose into USD/tonne and scans it daily (cached).
# PRICE_PROVIDER=metals-api          # metals-api | custom | mock
# PRICE_API_KEY=                     # your metals-api.com access key
# PRICE_BASE=USD
# PRICE_REFRESH_HOURS=12             # how often the daily scan refreshes the cache
# Calibration so the numbers match LME exactly (provider unit conventions vary):
# PRICE_INVERT=yes                   # metals-api returns base/symbol -> invert (default yes for metals-api)
# PRICE_UNIT=tonne                   # tonne | lb | oz  (lb/oz are converted to per-tonne)
# PRICE_MULT=1                       # extra multiplier if you need to fine-tune
# For PRICE_PROVIDER=custom, point this at an endpoint returning normalized JSON
# { "copper":9250, "aluminium":2350, "zinc":2700, "lead":2050, "nickel":16500,
#   "premium":290, "premiums":{"aluminium":290}, "source":"...", "asOf":1730000000000 }:
# PRICE_FEED_URL=https://your-endpoint.example.com/prices

# EU premiums: LME duty-paid premiums are licensed (Fastmarkets). Point this at a
# feed you're licensed for (or your own endpoint) returning { "aluminium":290, ... } USD/MT.
# Leave blank to enter premiums manually in the app.
# PREMIUM_FEED_URL=https://your-endpoint.example.com/premiums

# ---- Team sync (optional) ----
# The proxy shares the app's data at GET|PUT /api/data (file-backed).
# Set a shared secret so only your team can read/write it (the same value
# goes in each teammate's app under Settings -> Team sync -> token).
# DATA_AUTH_TOKEN=choose-a-long-random-string
